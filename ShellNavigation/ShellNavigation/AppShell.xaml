<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ShellNavigation.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ShellNavigation"
    xmlns:Pages="clr-namespace:ShellNavigation.Pages"
    Title="ShellNavigation">
    
    <FlyoutItem Title="Home Pages">
        <Tab Title="Tab">
            <ShellContent Title="Page 1" ContentTemplate="{DataTemplate Pages:Page1}"/>
            <ShellContent Title="Page 2" ContentTemplate="{DataTemplate Pages:Page2}"/>
        </Tab>
    <ShellContent Title="Page 3" ContentTemplate="{DataTemplate Pages:Page3}"/>
    </FlyoutItem>
    <ShellContent Title="Page 4" ContentTemplate="{DataTemplate Pages:Page4}"/>
    <ShellContent Title="Page 5" ContentTemplate="{DataTemplate Pages:Page5}"/>

</Shell>
